.container {
  padding: 20rpx;
}

/* 头部 */
.header {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 分类网格 */
.categories-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-card {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid var(--primary);
  transition: transform 0.2s;
}

.category-card:active {
  transform: scale(0.98);
}

.category-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.category-desc {
  font-size: 24rpx;
  color: var(--text-light);
}

.category-arrow {
  font-size: 36rpx;
  color: var(--text-light);
}

/* 错题本入口 */
.error-book-entry {
  background: linear-gradient(135deg, #FFF5F5, #FFF);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  border: 2rpx solid #FFD4D4;
}

.error-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.error-info {
  flex: 1;
}

.error-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--error);
  display: block;
}

.error-count {
  font-size: 24rpx;
  color: var(--text-light);
}

.error-arrow {
  font-size: 36rpx;
  color: var(--error);
}

/* 进度头部 */
.progress-header {
  margin-bottom: 30rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.streak-info {
  display: flex;
  align-items: center;
  background: rgba(255, 107, 53, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.streak-fire {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.streak-count {
  font-size: 26rpx;
  color: var(--accent);
  font-weight: 600;
}

/* 单词卡片 */
.word-card {
  background: var(--bg-white);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 3rpx solid transparent;
  transition: border-color 0.3s;
}

.word-card.correct {
  border-color: var(--success);
}

.word-card.wrong {
  border-color: var(--error);
}

.word-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.word-category-tag {
  background: rgba(30, 95, 142, 0.1);
  color: var(--primary);
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.audio-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: rgba(30, 95, 142, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-icon {
  font-size: 28rpx;
}

.word-content {
  text-align: center;
  margin-bottom: 30rpx;
}

.word-text {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
  font-family: 'Courier New', monospace;
}

.word-phonetic {
  font-size: 30rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.word-meaning {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 500;
}

/* 例句 */
.word-example {
  background: var(--bg-gray);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.example-label {
  font-size: 22rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: 8rpx;
}

.example-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-style: italic;
  line-height: 1.5;
}

/* 结果提示 */
.result-hint {
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.correct-hint {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success);
}

.wrong-hint {
  background: rgba(245, 34, 45, 0.1);
  color: var(--error);
}

.correct-answer {
  display: block;
  font-size: 26rpx;
  margin-top: 8rpx;
  font-weight: 400;
}

/* 模式切换 */
.mode-switch {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.mode-btn {
  flex: 1;
  background: var(--bg-white);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  border: 2rpx solid var(--border);
  transition: all 0.3s;
}

.mode-btn.active {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

/* 输入区域 */
.input-section {
  margin-bottom: 30rpx;
}

.word-input {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 36rpx;
  text-align: center;
  border: 3rpx solid var(--border);
  margin-bottom: 16rpx;
  font-family: 'Courier New', monospace;
}

.word-input:focus {
  border-color: var(--primary);
}

.word-input.input-error {
  border-color: var(--error);
  background: #FFF5F5;
}

.input-hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light);
}

/* 选项区域 */
.options-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.option-btn {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  border: 2rpx solid var(--border);
  display: flex;
  flex-direction: column;
  transition: all 0.2s;
}

.option-btn:active {
  background: var(--primary);
  border-color: var(--primary);
}

.option-btn:active .option-word,
.option-btn:active .option-meaning {
  color: white;
}

.option-word {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  font-family: 'Courier New', monospace;
}

.option-meaning {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 统计栏 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.stat-value.correct {
  color: var(--success);
}

.stat-value.wrong {
  color: var(--error);
}

/* 完成界面 */
.finish-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.finish-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.finish-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 40rpx;
}

.finish-stats {
  width: 100%;
  margin-bottom: 40rpx;
}

.stat-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 30rpx 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-box .stat-number {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.stat-box .stat-number.correct {
  color: var(--success);
}

.stat-box .stat-number.wrong {
  color: var(--error);
}

.accuracy-section {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
}

.accuracy-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.accuracy-value {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
  margin-bottom: 16rpx;
}

.accuracy-bar {
  height: 16rpx;
  background: var(--bg-gray);
  border-radius: 8rpx;
  overflow: hidden;
}

.accuracy-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-light));
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.achievement-section {
  background: linear-gradient(135deg, #FFF5E6, #FFF);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  border: 2rpx solid #FFD8A8;
}

.achievement-text {
  font-size: 28rpx;
  color: var(--accent);
  font-weight: 500;
}

.finish-buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.finish-buttons button {
  width: 100%;
}
