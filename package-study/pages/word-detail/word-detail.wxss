.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 单词头部 */
.word-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.word-text {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: 'Courier New', monospace;
}

.word-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: var(--bg-white);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.action-icon {
  font-size: 28rpx;
}

/* 单词信息卡片 */
.word-info-card {
  background: var(--bg-white);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.phonetic-row {
  margin-bottom: 16rpx;
}

.phonetic-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.meaning-row {
  margin-bottom: 16rpx;
}

.meaning-text {
  font-size: 36rpx;
  color: var(--primary);
  font-weight: 600;
}

.error-phonetic {
  background: rgba(245, 34, 45, 0.1);
  border-radius: 12rpx;
  padding: 16rpx;
}

.error-label {
  font-size: 24rpx;
  color: var(--error);
  display: block;
  margin-bottom: 8rpx;
}

.error-text {
  font-size: 26rpx;
  color: var(--error);
  display: block;
  margin-bottom: 4rpx;
}

/* 例句卡片 */
.example-card {
  background: var(--bg-white);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.example-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  font-style: italic;
}

/* 分类卡片 */
.category-card {
  background: var(--bg-white);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.category-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.category-tag {
  background: rgba(30, 95, 142, 0.1);
  color: var(--primary);
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 操作按钮 */
.action-buttons {
  margin-top: 30rpx;
}

.action-btn-large {
  background: linear-gradient(135deg, var(--accent), var(--accent-light));
  color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 500;
}
