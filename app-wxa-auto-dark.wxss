@media (prefers-color-scheme: dark) {
    page {
        --primary: rgb(115, 169, 221);
        --primary-light: rgb(61, 138, 196);
        --accent: rgb(181, 39, 0);
        --accent-light: rgb(145, 45, 1);
        --success: rgb(0, 99, 0);
        --warning: rgb(107, 51, 0);
        --error: rgb(238, 20, 40);
        --text-primary: rgb(209, 209, 209);
        --text-secondary: rgb(149, 149, 149);
        --text-light: rgb(99, 99, 99);
        --bg-gray: rgb(24, 24, 24);
        --bg-white: rgb(17, 17, 17);
        --border: rgb(34, 34, 34);
    }

    .btn-primary {
        color: rgb(17, 17, 17);
    }

    .btn-accent {
        color: rgb(17, 17, 17);
    }

    .tag-primary {
        background: rgba(115, 169, 221, 0.1);
    }

    .tag-accent {
        background: rgba(181, 39, 0, 0.1);
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20rpx);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }
    }
}
