.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 头部 */
.header {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 场景网格 */
.scenes-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scene-card {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid var(--accent);
  transition: transform 0.2s;
}

.scene-card:active {
  transform: scale(0.98);
}

.scene-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.scene-info {
  flex: 1;
}

.scene-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.scene-desc {
  font-size: 24rpx;
  color: var(--text-light);
}

.scene-progress {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.dialog-count {
  font-size: 24rpx;
  color: var(--accent);
  background: rgba(255, 107, 53, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 4rpx;
}

.scene-arrow {
  font-size: 36rpx;
  color: var(--text-light);
}

/* 场景练习头部 */
.scene-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.back-btn {
  font-size: 28rpx;
  color: var(--primary);
  padding: 8rpx;
}

.scene-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.scene-title .scene-icon {
  font-size: 36rpx;
  margin: 0;
}

.scene-title .scene-name {
  font-size: 32rpx;
  font-weight: 600;
  margin: 0;
}

.progress-info {
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-gray);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: var(--bg-gray);
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--accent-light));
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 模式切换 */
.mode-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  background: var(--bg-white);
  border-radius: 12rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.3s;
}

.mode-tab.active {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white;
}

/* 角色切换 */
.role-switch {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: var(--bg-white);
  border-radius: 12rpx;
}

.role-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.role-btn {
  background: linear-gradient(135deg, var(--accent), var(--accent-light));
  color: white;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

/* 对话内容 */
.dialog-content {
  margin-bottom: 20rpx;
}

.dialog-card {
  background: var(--bg-white);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.role-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.role-badge.sales {
  background: rgba(30, 95, 142, 0.1);
  color: var(--primary);
}

.role-badge.customer {
  background: rgba(255, 107, 53, 0.1);
  color: var(--accent);
}

.dialog-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 32rpx;
  padding: 8rpx;
}

.dialog-text {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.english-text {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.6;
  font-weight: 500;
}

.chinese-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border);
}

/* 练习操作 */
.practice-actions {
  display: flex;
  justify-content: center;
}

.record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white;
  padding: 30rpx 60rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(30, 95, 142, 0.3);
}

.record-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.record-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* 常用句型 */
.phrases-section {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.phrases-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.phrases-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.close-btn {
  font-size: 28rpx;
  color: var(--text-light);
  padding: 8rpx;
}

.phrases-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.phrase-item {
  background: var(--bg-gray);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  transition: all 0.2s;
}

.phrase-item:active {
  background: var(--primary);
}

.phrase-item:active .phrase-en,
.phrase-item:active .phrase-cn {
  color: white;
}

.phrase-en {
  font-size: 26rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.phrase-cn {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 底部控制 */
.bottom-controls {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx;
  background: var(--bg-white);
  border-top: 1rpx solid var(--border);
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.control-btn {
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-gray);
  transition: all 0.2s;
}

.control-btn.primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white;
}

.control-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
