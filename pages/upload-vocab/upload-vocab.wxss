.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #666;
}

.exam-list {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.exam-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.exam-item:last-child {
  border-bottom: none;
}

.exam-info {
  flex: 1;
}

.exam-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.exam-id {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}

.exam-status {
  margin-right: 20rpx;
}

.status-text {
  font-size: 24rpx;
  color: #666;
}

.upload-btn {
  margin: 0;
}

.footer {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  text-align: center;
}

.upload-all-btn {
  margin-bottom: 20rpx;
}

.tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}
