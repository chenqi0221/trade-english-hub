.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-gray);
}

/* 话题选择 */
.topics-section {
  padding: 30rpx;
  background: var(--bg-white);
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 20rpx;
}

.topics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.topic-card {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  color: white;
  transition: transform 0.2s;
}

.topic-card:active {
  transform: scale(0.95);
}

.topic-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 8rpx;
}

.topic-name {
  font-size: 26rpx;
  font-weight: 500;
}

/* 聊天消息 */
.chat-messages {
  flex: 1;
  padding: 20rpx;
}

.message-wrapper {
  margin-bottom: 20rpx;
}

.message {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.ai-message {
  justify-content: flex-start;
}

.user-message {
  justify-content: flex-end;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  margin-right: 16rpx;
}

.user-avatar {
  background: linear-gradient(135deg, var(--accent), var(--accent-light));
  margin-left: 16rpx;
}

.message-content {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.message-bubble {
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 8rpx;
}

.ai-bubble {
  background: var(--bg-white);
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.tip-bubble {
  background: linear-gradient(135deg, #FFF9E6, #FFF5E6);
  border: 2rpx solid #FFD8A8;
}

.user-bubble {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white;
  border-bottom-right-radius: 4rpx;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.5;
  display: block;
  margin-bottom: 8rpx;
}

.message-chinese {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid var(--border);
}

.user-bubble .message-chinese {
  color: rgba(255, 255, 255, 0.8);
  border-top-color: rgba(255, 255, 255, 0.3);
}

.message-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-btn {
  font-size: 28rpx;
  padding: 4rpx;
}

.timestamp {
  font-size: 20rpx;
  color: var(--text-light);
}

/* 加载中 */
.loading-message {
  display: flex;
  align-items: flex-start;
}

.loading-bubble {
  background: var(--bg-white);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: var(--primary);
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.bottom-space {
  height: 40rpx;
}

/* 快捷功能栏 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: var(--bg-white);
  border-top: 1rpx solid var(--border);
}

.quick-btn {
  background: var(--bg-gray);
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.quick-btn:active {
  background: var(--primary);
  color: white;
}

/* 输入区域 */
.input-section {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg-white);
  border-top: 1rpx solid var(--border);
  gap: 16rpx;
}

.voice-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: var(--bg-gray);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.voice-icon {
  font-size: 28rpx;
}

.voice-icon.recording {
  color: var(--error);
  animation: pulse 1s infinite;
}

.message-input {
  flex: 1;
  background: var(--bg-gray);
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  border: none;
  outline: none;
}

.send-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: var(--bg-gray);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
}

.send-icon {
  font-size: 28rpx;
  color: var(--text-light);
}

.send-btn.active .send-icon {
  color: white;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}
