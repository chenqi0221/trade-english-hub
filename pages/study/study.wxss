.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 概览卡片 */
.overview-card {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  color: white;
  box-shadow: 0 8rpx 24rpx rgba(30, 95, 142, 0.3);
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 32rpx;
  font-weight: 600;
}

.streak-badge {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.fire-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.streak-text {
  font-size: 24rpx;
  font-weight: 500;
}

.progress-stats {
  display: flex;
  justify-content: space-around;
}

.progress-item {
  text-align: center;
}

.progress-circle {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-number {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.progress-label {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 功能入口 */
.features-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 10rpx;
}

.feature-card {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.feature-card:active {
  transform: scale(0.95);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin: 0 auto 12rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 今日单词 */
.today-words-section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 10rpx;
}

.section-more {
  font-size: 24rpx;
  color: var(--primary);
}

.word-list {
  background: var(--bg-white);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.word-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid var(--border);
  transition: background 0.2s;
}

.word-item:last-child {
  border-bottom: none;
}

.word-item:active {
  background: var(--bg-gray);
}

.word-info {
  display: flex;
  flex-direction: column;
}

.word-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  font-family: 'Courier New', monospace;
}

.word-phonetic {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.word-meaning {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

/* 错题区域 */
.error-section {
  margin-bottom: 30rpx;
}

.error-list {
  background: var(--bg-white);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.error-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid var(--border);
  background: linear-gradient(135deg, #FFF5F5, #FFF);
}

.error-item:last-child {
  border-bottom: none;
}

.error-word-info {
  display: flex;
  flex-direction: column;
}

.error-word-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  font-family: 'Courier New', monospace;
}

.error-word-meaning {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.error-count {
  background: var(--error);
  color: white;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.error-count-text {
  font-size: 22rpx;
}

/* 分类浏览 */
.categories-section {
  margin-bottom: 30rpx;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 10rpx;
}

.category-item {
  background: var(--bg-white);
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s;
}

.category-item:active {
  transform: scale(0.98);
}

.category-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.category-desc {
  font-size: 22rpx;
  color: var(--text-light);
}

.category-arrow {
  font-size: 32rpx;
  color: var(--text-light);
}
