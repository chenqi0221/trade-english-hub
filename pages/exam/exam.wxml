<view class="container">
  <!-- 顶部学习概览 -->
  <view class="header-card">
    <view class="header-title">考试词汇学习</view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-number">{{studyProgress.masteredWords}}</text>
        <text class="stat-label">已掌握</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{studyProgress.totalWords}}</text>
        <text class="stat-label">总词数</text>
      </view>
    </view>
  </view>

  <!-- 考试卡片网格 -->
  <view class="section-title">选择考试类型</view>
  <view class="exams-grid">
    <view 
      class="exam-card"
      wx:for="{{exams}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="navigateToExamSelect"
      style="background: linear-gradient(135deg, {{item.color}}15, {{item.color}}05); border-color: {{item.color}}30"
    >
      <view class="exam-icon" style="background: {{item.color}}20; color: {{item.color}}">{{item.icon}}</view>
      <view class="exam-name">{{item.name}}</view>
      <view class="exam-count">{{item.wordCount}}词</view>
    </view>
  </view>
</view>
