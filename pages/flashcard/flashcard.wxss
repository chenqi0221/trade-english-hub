.container {
  padding: 30rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1E5F8E, #2E7FB8);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

/* 闪卡容器 */
.card-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 1000rpx;
  margin-bottom: 40rpx;
}

.flashcard {
  width: 90%;
  height: 600rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s;
}

.flashcard.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.card-back {
  transform: rotateY(180deg);
}

.word {
  font-size: 72rpx;
  font-weight: 700;
  color: #1E5F8E;
  margin-bottom: 20rpx;
}

.phonetic {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 60rpx;
}

.back-word {
  font-size: 48rpx;
  font-weight: 600;
  color: #1E5F8E;
  margin-bottom: 20rpx;
}

.meaning {
  font-size: 32rpx;
  color: #333;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.phrases {
  width: 100%;
}

.phrase-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.phrase {
  font-size: 28rpx;
  color: #1E5F8E;
  font-weight: 500;
}

.phrase-trans {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-around;
  padding: 0 40rpx 40rpx;
}

.btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 60rpx;
  border-radius: 16rpx;
  min-width: 200rpx;
}

.btn-unknown {
  background: #FFEBEE;
  color: #D9534F;
}

.btn-known {
  background: #E8F5E9;
  color: #5CB85C;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 32rpx;
  color: #666;
}
