.container {
  padding: 30rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1E5F8E, #2E7FB8);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

/* 播放区 */
.play-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.play-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1E5F8E, #2E7FB8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(30, 95, 142, 0.3);
  margin-bottom: 20rpx;
}

.play-btn.playing {
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.play-icon {
  font-size: 60rpx;
  margin-bottom: 8rpx;
}

.play-text {
  font-size: 24rpx;
  color: white;
}

.play-hint {
  font-size: 28rpx;
  color: #666;
}

/* 答案提示 */
.answer-hint {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: white;
  border-radius: 16rpx;
}

.answer-word {
  color: #1E5F8E;
  font-weight: 600;
  font-size: 36rpx;
}

/* 输入区 */
.input-section {
  margin-bottom: 40rpx;
}

.word-input {
  width: 100%;
  height: 120rpx;
  background: white;
  border-radius: 20rpx;
  padding: 0 40rpx;
  font-size: 40rpx;
  text-align: center;
  border: 2rpx solid #E0E0E0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.word-input.correct {
  border-color: #5CB85C;
  background: #E8F5E9;
}

.word-input.wrong {
  border-color: #D9534F;
  background: #FFEBEE;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.btn {
  padding: 24rpx 80rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.btn-skip {
  background: #F5F5F5;
  color: #666;
  border: 2rpx solid #E0E0E0;
}

.btn-check {
  background: linear-gradient(135deg, #1E5F8E, #2E7FB8);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(30, 95, 142, 0.3);
}

.btn-check:active {
  opacity: 0.8;
}
