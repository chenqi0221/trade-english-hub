.container {
  padding: 20rpx;
}

/* 头部 */
.header {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 常见错误提示 */
.error-tips-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
  padding: 0 10rpx;
}

.error-scroll {
  white-space: nowrap;
}

.error-cards {
  display: flex;
  gap: 16rpx;
  padding: 0 10rpx;
}

.error-card {
  background: linear-gradient(135deg, #FFF5F5, #FFF);
  border-radius: 16rpx;
  padding: 24rpx;
  min-width: 280rpx;
  border: 2rpx solid #FFD4D4;
  display: inline-block;
}

.error-word {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
  font-family: 'Courier New', monospace;
}

.phonetic-compare {
  margin-bottom: 12rpx;
}

.correct-phonetic {
  font-size: 26rpx;
  color: var(--success);
  display: block;
  margin-bottom: 4rpx;
}

.wrong-phonetic {
  font-size: 26rpx;
  color: var(--error);
  display: block;
}

.error-meaning {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 分类选择 */
.category-section {
  margin-bottom: 30rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 10rpx;
}

.category-item {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.category-item:active {
  transform: scale(0.95);
}

.category-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 练习区域 */
.practice-section {
  margin-top: 20rpx;
}

.progress-bar {
  height: 8rpx;
  background: var(--bg-gray);
  border-radius: 4rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-light));
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 发音卡片 */
.pronunciation-card {
  background: var(--bg-white);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.word-display {
  text-align: center;
  margin-bottom: 30rpx;
}

.word-text {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
  font-family: 'Courier New', monospace;
}

.word-meaning {
  font-size: 30rpx;
  color: var(--primary);
  font-weight: 500;
}

/* 音标区域 */
.phonetic-section {
  margin-bottom: 24rpx;
}

.correct-phonetic {
  background: rgba(82, 196, 26, 0.1);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.phonetic-label {
  font-size: 22rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: 8rpx;
}

.phonetic-text {
  font-size: 32rpx;
  color: var(--success);
  font-weight: 600;
}

.play-btn {
  display: flex;
  align-items: center;
  background: var(--success);
  color: white;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
}

.play-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.play-text {
  font-size: 24rpx;
}

/* 错误发音警示 */
.wrong-phonetic-section {
  background: rgba(245, 34, 45, 0.1);
  border-radius: 12rpx;
  padding: 20rpx;
}

.wrong-list {
  margin-top: 8rpx;
}

.wrong-phonetic-item {
  font-size: 28rpx;
  color: var(--error);
  display: block;
  margin-bottom: 4rpx;
}

/* 例句 */
.example-section {
  background: var(--bg-gray);
  border-radius: 12rpx;
  padding: 20rpx;
}

.example-label {
  font-size: 22rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: 8rpx;
}

.example-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-style: italic;
  line-height: 1.5;
}

/* 控制按钮 */
.control-buttons {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 30rpx;
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.control-btn.primary {
  background: rgba(30, 95, 142, 0.1);
}

.control-btn.recording {
  background: rgba(245, 34, 45, 0.1);
  animation: pulse 1s infinite;
}

.btn-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.btn-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 录音对比 */
.comparison-section {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.comparison-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
  text-align: center;
}

.comparison-buttons {
  display: flex;
  gap: 20rpx;
}

.compare-btn {
  flex: 1;
  background: var(--bg-gray);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  transition: all 0.2s;
}

.compare-btn:active {
  background: var(--primary);
  color: white;
}

/* 显示控制 */
.display-controls {
  display: flex;
  justify-content: center;
  gap: 30rpx;
}

.display-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
}

.display-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.display-text {
  font-size: 22rpx;
  color: var(--text-light);
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}
