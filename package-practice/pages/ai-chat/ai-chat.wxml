<view class="container">
  <!-- 话题选择 -->
  <view class="topics-section" wx:if="{{showTopics}}">
    <text class="section-title">选择练习话题</text>
    <view class="topics-grid">
      <view 
        class="topic-card"
        wx:for="{{topics}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        bindtap="selectTopic"
      >
        <text class="topic-icon">{{item.icon}}</text>
        <text class="topic-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 聊天区域 -->
  <scroll-view 
    class="chat-messages" 
    scroll-y 
    scroll-into-view="{{scrollToBottom}}"
    enhanced
    show-scrollbar
  >
    <view 
      class="message-wrapper"
      wx:for="{{messages}}"
      wx:key="id"
      id="msg-{{index}}"
    >
      <!-- AI消息 -->
      <view class="message ai-message" wx:if="{{item.role === 'ai'}}">
        <view class="avatar ai-avatar">🤖</view>
        <view class="message-content">
          <view class="message-bubble ai-bubble {{item.isTip ? 'tip-bubble' : ''}} {{item.streaming ? 'streaming-bubble' : ''}}">
            <text class="message-text">{{item.text}}</text>
            <text class="streaming-cursor" wx:if="{{item.streaming}}">|</text>
            <text class="message-chinese" wx:if="{{item.chinese}}">{{item.chinese}}</text>
          </view>
          <view class="message-actions">
            <text class="action-btn" bindtap="playMessageAudio" data-text="{{item.text}}">🔊</text>
            <text class="timestamp">{{item.timestamp}}</text>
          </view>
        </view>
      </view>

      <!-- 用户消息 -->
      <view class="message user-message" wx:if="{{item.role === 'user'}}">
        <view class="message-content">
          <view class="message-bubble user-bubble">
            <text class="message-text">{{item.text}}</text>
          </view>
          <text class="timestamp">{{item.timestamp}}</text>
        </view>
        <view class="avatar user-avatar">👤</view>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="loading-message" wx:if="{{isLoading && !messages[messages.length-1].streaming}}">
      <view class="avatar ai-avatar">🤖</view>
      <view class="loading-bubble">
        <text class="loading-text">思考中</text>
        <view class="loading-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <!-- 快捷功能栏 -->
  <view class="quick-actions" wx:if="{{!showTopics}}">
    <view class="quick-btn" bindtap="toggleTopics">
      <text>📋 话题</text>
    </view>
    <view class="quick-btn" bindtap="getGrammarTip">
      <text>💡 语法</text>
    </view>
    <view class="quick-btn" bindtap="clearChat">
      <text>🗑️ 清空</text>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-section">
    <view class="voice-btn" bindtap="{{isRecording ? 'stopVoiceInput' : 'startVoiceInput'}}">
      <text class="voice-icon {{isRecording ? 'recording' : ''}}">{{isRecording ? '⏹️' : '🎙️'}}</text>
    </view>
    
    <input 
      class="message-input"
      type="text"
      placeholder="输入英语练习对话..."
      value="{{inputText}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    
    <view class="send-btn {{inputText ? 'active' : ''}}" bindtap="sendMessage">
      <text class="send-icon">📤</text>
    </view>
  </view>
</view>
